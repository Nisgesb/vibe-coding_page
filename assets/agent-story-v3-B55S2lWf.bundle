            <path class="agent-link" data-start="0.77" pathLength="1" marker-end="url(#agent-arrow-call)" d="M47 80 C39 84 34 88 29 92" />
            <path class="agent-link" data-start="0.80" pathLength="1" marker-end="url(#agent-arrow-call)" d="M53 80 C61 84 66 88 71 92" />
            <path class="agent-link route-return" data-start="0.35" pathLength="1" marker-end="url(#agent-arrow-return)" d="M22 50 C30 53 37 54 44 52" />
            <path class="agent-link route-return" data-start="0.63" pathLength="1" marker-end="url(#agent-arrow-return)" d="M78 50 C70 53 63 54 56 52" />
